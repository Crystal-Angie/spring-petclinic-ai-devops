# Terraform state files (NEVER commit - contains sensitive data)
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Terraform directories
.terraform/
.terraform.d/

# Environment-specific tfvars (except examples)
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan files
*tfplan*

# OS files
.DS_Store

# IDE files
.idea/
.vscode/
*.swp
*.swo
